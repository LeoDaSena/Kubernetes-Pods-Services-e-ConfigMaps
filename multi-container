apiVersion: v1
kind: Pod
metadata:
    name: multi-container
spec: 
    containers:
    # Container principal
    - name: app
      image: nginx:1.27
      ports:
        - containerPort: 80 

    # Container auxiliar (sidecar)
    - name: sidecar
    image: alpine:3.18
    command: ["sleep", "3600"]